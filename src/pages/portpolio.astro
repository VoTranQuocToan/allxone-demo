---
const portfolios = [
  {
    title: "E-Commerce Platform",
    category: "Web Development",
    desc: "Hệ thống thương mại điện tử với thanh toán online, quản lý đơn hàng.",
    tech: ["React", "Node.js", "MongoDB"],
    image: "https://picsum.photos/600/400?random=1"
  },
  {
    title: "AI Recruitment System",
    category: "AI & Big Data",
    desc: "Nền tảng tuyển dụng thông minh sử dụng AI.",
    tech: ["Python", "TensorFlow"],
    image: "https://picsum.photos/600/400?random=2"
  },
  {
    title: "Mobile Banking App",
    category: "Mobile App",
    desc: "Ứng dụng ngân hàng số hiện đại.",
    tech: ["Flutter", "Firebase"],
    image: "https://picsum.photos/600/400?random=3"
  }
];
---

<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

  <title>Portfolio - AllXOne</title>

  <!-- FONT GIỐNG HOME -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">

  <style>
    /* RESET + THEME GIỐNG TRANG TRƯỚC */
    * { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --bg: #060810;
      --bg2: #0c1020;
      --bg3: #111827;
      --accent: #00e5ff;
      --accent2: #7c3aed;
      --text: #f0f4ff;
      --muted: #8892a4;
      --border: rgba(255,255,255,0.07);
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Inter', sans-serif;
    }

    .container {
      max-width: 1200px;
      margin: auto;
      padding: 0 2rem;
    }

    /* HERO */
    .portfolio-hero {
      padding: 120px 2rem 60px;
      text-align: center;
      background: var(--bg2);
      border-bottom: 1px solid var(--border);
    }

    .portfolio-hero h1 {
      font-size: 3rem;
      font-weight: 800;
    }

    .portfolio-hero p {
      color: var(--muted);
      margin-top: 10px;
    }

    /* GRID */
    .portfolio-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 1.5rem;
      padding: 60px 0;
    }

    /* CARD */
    .portfolio-card {
      background: var(--bg3);
      border: 1px solid var(--border);
      border-radius: 16px;
      overflow: hidden;
      transition: 0.3s;
    }

    .portfolio-card:hover {
      transform: translateY(-5px);
      border-color: rgba(0,229,255,0.3);
    }

    /* IMAGE */
    .portfolio-img {
      height: 200px;
      overflow: hidden;
    }

    .portfolio-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    /* BODY */
    .portfolio-body {
      padding: 1.5rem;
    }

    .portfolio-category {
      font-size: 0.7rem;
      color: var(--accent2);
      font-family: monospace;
    }

    .portfolio-body h3 {
      margin: 0.5rem 0;
      font-size: 1.2rem;
    }

    .portfolio-body p {
      color: var(--muted);
      font-size: 0.9rem;
    }

    /* TECH */
    .portfolio-tech {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin: 12px 0;
    }

    .portfolio-tech span {
      font-size: 0.7rem;
      background: rgba(0,229,255,0.06);
      border: 1px solid rgba(0,229,255,0.2);
      padding: 3px 8px;
      border-radius: 6px;
      color: var(--accent);
    }

    /* LINK */
    .portfolio-link {
      font-size: 0.85rem;
      color: var(--accent);
      text-decoration: none;
    }

    .portfolio-link:hover {
      text-decoration: underline;
    }
  </style>
</head>

<body>

<section class="portfolio-hero">
  <div class="container">
    <h1>Dự án & Portfolio</h1>
    <p>Những sản phẩm tiêu biểu mà chúng tôi đã thực hiện</p>
  </div>
</section>

<div class="container">
  <div class="portfolio-grid">
    {portfolios.map((p) => (
      <div class="portfolio-card">
        
        <div class="portfolio-img">
          <img src={p.image} alt={p.title} />
        </div>

        <div class="portfolio-body">
          <span class="portfolio-category">{p.category}</span>
          <h3>{p.title}</h3>
          <p>{p.desc}</p>

          <div class="portfolio-tech">
            {p.tech.map(t => <span>{t}</span>)}
          </div>

          <a href="#" class="portfolio-link">Xem chi tiết →</a>
        </div>

      </div>
    ))}
  </div>
</div>

</body>
</html>
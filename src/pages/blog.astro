---
const blogs = [
  {
    title: "Xu hướng AI trong doanh nghiệp 2025",
    desc: "Khám phá cách AI đang thay đổi vận hành doanh nghiệp hiện đại.",
    category: "AI",
    date: "2026-04-01",
    image: "https://picsum.photos/600/400?1"
  },
  {
    title: "Cloud Computing là gì?",
    desc: "Tổng quan về Cloud và cách doanh nghiệp tận dụng hiệu quả.",
    category: "Cloud",
    date: "2026-03-28",
    image: "https://picsum.photos/600/400?2"
  },
  {
    title: "Blockchain trong thực tế",
    desc: "Ứng dụng blockchain ngoài crypto.",
    category: "Blockchain",
    date: "2026-03-20",
    image: "https://picsum.photos/600/400?3"
  },
];
---

<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <title>Blogs — AllXOne</title>
</head>

<body>

<!-- HERO -->
<section class="hero">
  <div class="container">
    <span class="section-tag">// BLOGS</span>
    <h1>Kiến thức & <span class="accent">Công nghệ</span></h1>
    <p>Cập nhật xu hướng mới nhất về IT, AI, Cloud và phát triển phần mềm</p>
  </div>
</section>

<!-- FILTER -->
<section class="filter">
  <div class="container">
    <button class="active">All</button>
    <button>AI</button>
    <button>Cloud</button>
    <button>Blockchain</button>
  </div>
</section>

<!-- BLOG LIST -->
<section class="section">
  <div class="container">
    <div class="grid">
      {blogs.map(blog => (
        <div class="blog-card">
          <img src={blog.image} alt={blog.title} />
          <div class="content">
            <span class="category">{blog.category}</span>
            <h3>{blog.title}</h3>
            <p>{blog.desc}</p>
            <div class="meta">
              <span>{blog.date}</span>
              <a href="#">Đọc thêm →</a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- LOAD MORE -->
<section class="load-more">
  <button>Xem thêm</button>
</section>

<style>
:root {
  --bg: #060810;
  --bg2: #0c1020;
  --text: #f0f4ff;
  --muted: #8892a4;
  --accent: #00e5ff;
}

body {
  background: var(--bg);
  color: var(--text);
  font-family: Inter, sans-serif;
}

/* HERO */
.hero {
  padding: 120px 2rem 60px;
  text-align: center;
}

.hero h1 {
  font-size: 3rem;
  font-weight: 800;
}

.hero p {
  color: var(--muted);
  margin-top: 1rem;
}

.section-tag {
  color: var(--accent);
  font-size: 0.8rem;
}

.accent {
  color: var(--accent);
}

/* FILTER */
.filter {
  text-align: center;
  margin-bottom: 2rem;
}

.filter button {
  margin: 0 5px;
  padding: 0.5rem 1rem;
  border: none;
  background: rgba(255,255,255,0.05);
  color: var(--text);
  border-radius: 8px;
  cursor: pointer;
}

.filter .active {
  background: var(--accent);
  color: black;
}

/* GRID */
.section {
  padding: 4rem 0;
}

.container {
  max-width: 1100px;
  margin: auto;
  padding: 0 2rem;
}

.grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px,1fr));
  gap: 1.5rem;
}

/* BLOG CARD */
.blog-card {
  background: var(--bg2);
  border-radius: 14px;
  overflow: hidden;
  border: 1px solid rgba(255,255,255,0.08);
  transition: transform 0.3s;
}

.blog-card:hover {
  transform: translateY(-5px);
}

.blog-card img {
  width: 100%;
  height: 200px;
  object-fit: cover;
}

.content {
  padding: 1.5rem;
}

.category {
  font-size: 0.7rem;
  color: var(--accent);
}

.content h3 {
  margin: 0.5rem 0;
}

.content p {
  color: var(--muted);
  font-size: 0.9rem;
}

.meta {
  display: flex;
  justify-content: space-between;
  margin-top: 1rem;
  font-size: 0.8rem;
}

.meta a {
  color: var(--accent);
  text-decoration: none;
}

/* LOAD MORE */
.load-more {
  text-align: center;
  padding: 2rem;
}

.load-more button {
  padding: 0.7rem 1.5rem;
  background: var(--accent);
  border: none;
  border-radius: 8px;
  cursor: pointer;
}
</style>

</body>
</html>